rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Appointments: each document belongs to one user via its ownerId field.
    match /appointments/{appointmentId} {

      // Read existing docs only if you own them.
      allow read: if request.auth != null
                  && resource.data.ownerId == request.auth.uid;

      // Create only if you're signed in and stamping the doc with YOUR uid.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Update/delete only docs you own, and you can't reassign ownership.
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // Everything else is denied by default.
  }
}
